rules_version = '2';

// Elysian Studios — Firestore security rules.
// Publish in: Firebase console → Firestore Database → Rules → Publish.
//
// Posts are publicly readable (the website needs them). Writes are locked to
// the single admin account by UID — important, because Firebase Email/Password
// lets anyone self-register, so "any signed-in user" would NOT be safe.
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'QkI9jlewsgbJ1mCKWTLcl4lEl3q1';
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
