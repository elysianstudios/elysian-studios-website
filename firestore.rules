rules_version = '2';

// Elysian Studios — Firestore security rules.
// Publish these in: Firebase console → Firestore Database → Rules → Publish.
//
// Posts are publicly readable (the website needs them), but only a signed-in
// admin (Firebase Auth) can create, edit, or delete them.
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
